
/* ADBS Safe Unified CSS */

:root {
  --adbs-blue: #005F93;
  --adbs-blue-dark: #004B75;
  --adbs-navy: #12212E;
  --adbs-muted: #6B7280;
  --adbs-bg: #F3F6F8;
  --adbs-border: #DCE3E8;
}

/* Base */
html {
  scroll-behavior: smooth;
}

body {
  background: var(--adbs-bg);
  color: var(--adbs-navy);
}

/* Navbar */
nav {
  background: rgba(255, 255, 255, 0.96) !important;
  border-bottom: 1px solid rgba(220, 227, 232, 0.85);
  box-shadow: 0 8px 24px rgba(18, 33, 46, 0.04);
}

nav a:hover {
  color: var(--adbs-blue) !important;
}

nav a:focus,
nav button:focus {
  outline: none !important;
  box-shadow: none !important;
}

/* Logo */
img[alt="ADBS Logo"] {
  height: 72px !important;
  max-height: 72px !important;
  width: auto !important;
  object-fit: contain !important;
}

/* Typography */
h1,
h2,
h3 {
  color: var(--adbs-navy);
}

p {
  color: var(--adbs-muted);
  line-height: 1.8;
}

/* Inputs */
input,
textarea,
select {
  background: #F3F6F8 !important;
  border: 1px solid var(--adbs-border) !important;
  border-radius: 14px !important;
  color: var(--adbs-navy) !important;
}

input:focus,
textarea:focus,
select:focus {
  outline: none !important;
  border-color: var(--adbs-blue) !important;
  box-shadow: 0 0 0 4px rgba(0, 95, 147, 0.12) !important;
}

/* Submit buttons */
button[type="submit"] {
  background: var(--adbs-blue) !important;
  color: white !important;
  border-radius: 14px !important;
  font-weight: 700 !important;
  box-shadow: 0 14px 30px rgba(0, 95, 147, 0.22);
}

button[type="submit"]:hover {
  background: var(--adbs-blue-dark) !important;
  transform: translateY(-2px);
}

/* Footer */
footer {
  background: #0F2433 !important;
  color: white !important;
}

footer * {
  background-color: transparent !important;
  text-decoration: none !important;
  border-bottom: none !important;
}

footer h1,
footer h2,
footer h3,
footer h4 {
  color: white !important;
}

footer p,
footer span,
footer li,
footer a {
  color: rgba(255, 255, 255, 0.72) !important;
}

footer a:hover {
  color: white !important;
}

/* Soft Animation */
@keyframes adbsSoftFadeUp {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

main section {
  animation: adbsSoftFadeUp 0.55s ease both;
}

main section:nth-of-type(1) {
  animation-delay: 0.03s;
}

main section:nth-of-type(2) {
  animation-delay: 0.08s;
}

main section:nth-of-type(3) {
  animation-delay: 0.13s;
}

main section:nth-of-type(4) {
  animation-delay: 0.18s;
}

/* Cards hover */
main [class*="rounded-2xl"],
main [class*="rounded-3xl"],
main [class*="rounded-[18px]"],
main [class*="rounded-[24px]"] {
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

main [class*="rounded-2xl"]:hover,
main [class*="rounded-3xl"]:hover,
main [class*="rounded-[18px]"]:hover,
main [class*="rounded-[24px]"]:hover {
  transform: translateY(-3px);
  box-shadow: 0 18px 42px rgba(0, 95, 147, 0.12);
}

/* Images */
main img {
  transition: transform 0.45s ease;
}

main img:hover {
  transform: scale(1.008);
}

/* Buttons and links */
button,
a {
  transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, color 0.25s ease;
}

button:hover,
a:hover {
  transform: translateY(-1px);
}

/* Do not animate navbar */
nav,
nav * {
  animation: none !important;
}

/* Mobile */
@media (max-width: 768px) {
  img[alt="ADBS Logo"] {
    height: 50px !important;
    max-height: 50px !important;
    width: auto !important;
  }

  h1 {
    font-size: clamp(38px, 10vw, 56px) !important;
    line-height: 1.2 !important;
  }
}

/* Reduce motion */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation: none !important;
    transition: none !important;
    transform: none !important;
  }
}

/* Bigger ADBS Logo in Navbar */
header img[alt="ADBS Logo"],
nav img[alt="ADBS Logo"],
img[alt="ADBS Logo"] {
  width: 170px !important;
  max-width: 170px !important;
  height: auto !important;
  object-fit: contain !important;
}

@media (min-width: 1024px) {
  header img[alt="ADBS Logo"],
  nav img[alt="ADBS Logo"],
  img[alt="ADBS Logo"] {
    width: 210px !important;
    max-width: 210px !important;
  }
}

@media (max-width: 768px) {
  header img[alt="ADBS Logo"],
  nav img[alt="ADBS Logo"],
  img[alt="ADBS Logo"] {
    width: 130px !important;
    max-width: 130px !important;
  }
}

/* Final navbar logo size */
header img[alt="ADBS Logo"],
nav img[alt="ADBS Logo"] {
  width: 155px !important;
  max-width: 155px !important;
  height: auto !important;
  max-height: 75px !important;
  object-fit: contain !important;
  transform: none !important;
  background: transparent !important;
}

@media (min-width: 1024px) {
  header img[alt="ADBS Logo"],
  nav img[alt="ADBS Logo"] {
    width: 175px !important;
    max-width: 175px !important;
    max-height: 85px !important;
  }
}

/* Reduce navbar logo size - final */
header img[alt="ADBS Logo"],
nav img[alt="ADBS Logo"] {
  width: 100px !important;
  max-width: 100px !important;
  max-height: 38px !important;
  height: auto !important;
  object-fit: contain !important;
  transform: none !important;
}

@media (min-width: 1024px) {
  header img[alt="ADBS Logo"],
  nav img[alt="ADBS Logo"] {
    width: 130px !important;
    max-width: 130px !important;
    max-height: 38px !important;
  }
}

/* Smaller final ADBS logo */
header img[alt="ADBS Logo"],
nav img[alt="ADBS Logo"] {
  width: 85px !important;
  max-width: 85px !important;
  max-height: 38px !important;
  height: auto !important;
  object-fit: contain !important;
  transform: none !important;
}

@media (min-width: 1024px) {
  header img[alt="ADBS Logo"],
  nav img[alt="ADBS Logo"] {
    width: 100px !important;
    max-width: 100px !important;
    max-height: 38px !important;
  }
}

/* ONLY shrink ADBS logo - do not change navbar height */
header img[alt="ADBS Logo"],
nav img[alt="ADBS Logo"] {
  width: 85px !important;
  max-width: 85px !important;
  height: auto !important;
  max-height: 38px !important;
  object-fit: contain !important;
  transform: none !important;
}

/* Make white navbar strip a little taller only */
header,
nav {
  min-height: 82px !important;
}

/* Keep logo size unchanged */
header img[alt="ADBS Logo"],
nav img[alt="ADBS Logo"] {
  width: 85px !important;
  max-width: 85px !important;
  max-height: 38px !important;
  height: auto !important;
  object-fit: contain !important;
}

/* =========================================================
   ADBS Luxury Creative Upgrade
   Same brand colors - no palette change
   ========================================================= */

:root {
  --adbs-shadow-soft: 0 18px 45px rgba(18, 33, 46, 0.08);
  --adbs-shadow-premium: 0 28px 80px rgba(18, 33, 46, 0.13);
  --adbs-ring-blue: rgba(0, 95, 147, 0.14);
  --adbs-glass: rgba(255, 255, 255, 0.72);
}

/* Premium page rhythm */
main {
  overflow: hidden;
}

main section {
  position: relative;
}

/* Subtle luxury background details */
main section::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 12% 18%, rgba(0, 95, 147, 0.075), transparent 28%),
    radial-gradient(circle at 88% 12%, rgba(18, 33, 46, 0.045), transparent 30%);
  opacity: 0.75;
}

main section > * {
  position: relative;
  z-index: 1;
}

/* Make white sections more premium without changing colors */
main section.bg-white,
main .bg-white {
  background:
    linear-gradient(180deg, rgba(255,255,255,1), rgba(255,255,255,0.96)) !important;
}

/* Premium headings */
main h1,
main h2 {
  letter-spacing: -0.045em;
}

main h2 {
  position: relative;
}

main h2 span {
  position: relative;
}

main h2 span::after {
  content: "";
  position: absolute;
  left: 4px;
  right: 4px;
  bottom: 0.05em;
  height: 0.22em;
  background: rgba(0, 95, 147, 0.12);
  z-index: -1;
  border-radius: 999px;
}

/* Luxury cards */
main [class*="rounded-2xl"],
main [class*="rounded-3xl"],
main [class*="rounded-xl"],
main [class*="rounded-[2rem]"] {
  border-color: rgba(220, 227, 232, 0.95) !important;
}

main [class*="rounded-2xl"]:not(img),
main [class*="rounded-3xl"]:not(img),
main [class*="rounded-xl"]:not(img) {
  box-shadow: 0 10px 30px rgba(18, 33, 46, 0.045);
}

/* Creative hover lift */
main [class*="rounded-2xl"]:hover,
main [class*="rounded-3xl"]:hover,
main [class*="rounded-xl"]:hover {
  transform: translateY(-6px);
  box-shadow: var(--adbs-shadow-premium);
  border-color: rgba(0, 95, 147, 0.24) !important;
}

/* Service cards premium inner glow */
main .group > div {
  position: relative;
  overflow: hidden;
}

main .group > div::before {
  content: "";
  position: absolute;
  inset: -1px;
  background:
    linear-gradient(135deg, rgba(0, 95, 147, 0.12), transparent 38%),
    radial-gradient(circle at top right, rgba(0, 95, 147, 0.12), transparent 34%);
  opacity: 0;
  transition: opacity 0.45s ease;
  pointer-events: none;
}

main .group:hover > div::before {
  opacity: 1;
}

/* Icon boxes feel more executive */
main .group [class*="w-14"][class*="h-14"] {
  box-shadow:
    inset 0 0 0 1px rgba(0, 95, 147, 0.12),
    0 14px 28px rgba(0, 95, 147, 0.12);
}

/* Why choose us list cards */
main section .grid .flex.gap-4 {
  transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
}

main section .grid .flex.gap-4:hover {
  transform: translateX(4px);
  box-shadow: var(--adbs-shadow-soft);
  border-color: rgba(0, 95, 147, 0.2) !important;
}

/* Image frame premium treatment */
main img {
  filter: saturate(1.03) contrast(1.02);
}

main .aspect-\[4\/5\] {
  position: relative;
  border-width: 1px !important;
  box-shadow: var(--adbs-shadow-premium);
}

main .aspect-\[4\/5\]::after {
  content: "";
  position: absolute;
  inset: 18px;
  border: 1px solid rgba(255,255,255,0.55);
  border-radius: 1.5rem;
  pointer-events: none;
}

/* CTA section more luxurious */
main section:last-of-type {
  background:
    linear-gradient(135deg, rgba(255,255,255,1), rgba(243,246,248,0.98)) !important;
}

main section:last-of-type .max-w-4xl {
  padding: clamp(2rem, 4vw, 4rem);
  border-radius: 2rem;
  border: 1px solid rgba(220, 227, 232, 0.9);
  background: rgba(255,255,255,0.72);
  box-shadow: var(--adbs-shadow-soft);
  backdrop-filter: blur(14px);
}

/* Premium buttons */
main a.bg-primary,
button[type="submit"] {
  position: relative;
  overflow: hidden;
  box-shadow: 0 18px 35px rgba(0, 95, 147, 0.22) !important;
}

main a.bg-primary::before,
button[type="submit"]::before {
  content: "";
  position: absolute;
  top: 0;
  left: -80%;
  width: 55%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.32), transparent);
  transform: skewX(-18deg);
  transition: left 0.65s ease;
}

main a.bg-primary:hover::before,
button[type="submit"]:hover::before {
  left: 130%;
}

/* Navbar premium polish */
nav {
  backdrop-filter: blur(18px);
  box-shadow: 0 14px 38px rgba(18, 33, 46, 0.075) !important;
}

nav a {
  position: relative;
}

nav a::after {
  content: "";
  position: absolute;
  left: 10%;
  right: 10%;
  bottom: -6px;
  height: 2px;
  background: var(--adbs-blue);
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.25s ease;
  border-radius: 999px;
}

nav a:hover::after {
  transform: scaleX(1);
}

/* Footer premium finish */
footer {
  position: relative;
  overflow: hidden;
}

footer::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 12% 15%, rgba(0, 95, 147, 0.18), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.035), transparent);
  pointer-events: none;
}

footer > * {
  position: relative;
  z-index: 1;
}

/* Mobile refinement */
@media (max-width: 768px) {
  main section {
    padding-top: 4.5rem !important;
    padding-bottom: 4.5rem !important;
  }

  main h2 {
    font-size: clamp(2rem, 8vw, 3.2rem) !important;
  }

  main section:last-of-type .max-w-4xl {
    padding: 1.5rem;
    border-radius: 1.5rem;
  }
}

