import React from 'react';
import { motion } from 'motion/react';
import {
  ArrowRight,
  ArrowLeft,
  CheckCircle2,
  BarChart3,
  Briefcase,
  Building2,
  TrendingUp,
  Sparkles,
  ShieldCheck,
  LineChart,
  Landmark,
} from 'lucide-react';
import { CinematicHeroV2 } from '../components/ui/CinematicHeroV2';
import { Link } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import { SEO } from '../components/common/SEO';

export const Home = () => {
  const { t, i18n } = useTranslation();
  const isRtl = i18n.language === 'ar';
  const ArrowIcon = isRtl ? ArrowLeft : ArrowRight;

  const services = [
    {
      title: t('home.services.formation.title'),
      desc: t('home.services.formation.desc'),
      icon: Building2,
      label: '01',
    },
    {
      title: t('home.services.management.title'),
      desc: t('home.services.management.desc'),
      icon: Briefcase,
      label: '02',
    },
    {
      title: t('home.services.tax.title'),
      desc: t('home.services.tax.desc'),
      icon: BarChart3,
      label: '03',
    },
    {
      title: t('home.services.development.title'),
      desc: t('home.services.development.desc'),
      icon: TrendingUp,
      label: '04',
    },
  ];

  const whyItems = [
    { title: t('home.why.items.precision'), desc: t('home.why.items.precision_desc') },
    { title: t('home.why.items.custom'), desc: t('home.why.items.custom_desc') },
    { title: t('home.why.items.expertise'), desc: t('home.why.items.expertise_desc') },
    { title: t('home.why.items.integrity'), desc: t('home.why.items.integrity_desc') },
  ];

  return (
    <main className="adbs-home-modern min-h-screen selection:bg-primary selection:text-white antialiased">
      <SEO titleKey="seo.home_title" descriptionKey="seo.home_desc" />
      <CinematicHeroV2 />

      <section className="adbs-section bg-white">
        <div className="adbs-container">
          <div className="adbs-section-head">
            <motion.div
              initial={{ opacity: 0, y: 22 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
            >
              <div className="adbs-eyebrow">
                <Sparkles size={15} />
                ADBS EXPERTISE
              </div>

              <h2 className="adbs-title">
                {t('home.services_title.main')}{' '}
                <span className="accent">{t('home.services_title.accent')}</span>{' '}
                {t('home.services_title.suffix')}
              </h2>
            </motion.div>

            <motion.p
              initial={{ opacity: 0, y: 22 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ delay: 0.08 }}
              className="adbs-lead"
            >
              {t('hero.description')}
            </motion.p>
          </div>

          <div className="adbs-bento">
            <motion.div
              initial={{ opacity: 0, scale: 0.97 }}
              whileInView={{ opacity: 1, scale: 1 }}
              viewport={{ once: true }}
              className="adbs-feature-card"
            >
              <img
                src="https://images.unsplash.com/photo-1556761175-4b46a572b786?q=80&w=1600&auto=format&fit=crop"
                alt="Business Consulting"
              />

              <div className="adbs-feature-content">
                <div className="adbs-feature-icon">
                  <Landmark size={30} />
                </div>

                <div>
                  <h3>حلول أعمال مصممة للنمو بثقة.</h3>
                  <p>
                    ندمج الخبرة المالية والإدارية مع فهم السوق المحلي لتقديم حلول عملية وواضحة.
                  </p>

                  <div className="adbs-feature-actions">
                    <Link to="/contact" className="adbs-primary-link">
                      {t('services.cta_button')}
