                  initial={{ opacity: 0, y: 22 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ delay: index * 0.06 }}
                  className="adbs-service-card"
                  data-number={service.label}
                >
                  <div className="adbs-service-icon">
                    <service.icon size={25} />
                  </div>

                  <h3>{service.title}</h3>
                  <p>{service.desc}</p>

                  <Link to="/services" className="adbs-text-link">
                    {t('home.services.view_details')}
                    <ArrowIcon size={14} />
                  </Link>
                </motion.div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section className="adbs-metrics-section">
        <div className="adbs-metrics-grid">
          {[
            ['2014', 'خبرة منذ'],
            ['360°', 'حلول متكاملة'],
            ['ADBS', 'شريك أعمال'],
            ['JO', 'خبرة محلية'],
          ].map(([value, label], index) => (
            <motion.div
              key={value}
              initial={{ opacity: 0, y: 16 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ delay: index * 0.05 }}
              className="adbs-metric"
            >
              <strong>{value}</strong>
              <span>{label}</span>
            </motion.div>
          ))}
        </div>
      </section>

      <section className="adbs-section">
        <div className="adbs-container adbs-why">
          <motion.div
            initial={{ opacity: 0, x: isRtl ? 34 : -34 }}
            whileInView={{ opacity: 1, x: 0 }}
            viewport={{ once: true }}
            className="adbs-image-frame"
          >
            <img
              src="https://images.unsplash.com/photo-1556761175-b413da4baf72?q=80&w=1600&auto=format&fit=crop"
              alt="Boardroom Meeting"
            />

            <div className="adbs-floating-note">
              <div className="text-primary mb-3">
                <LineChart size={24} />
              </div>
              <p>قرارات أدق. نمو أوضح. تنفيذ أقوى.</p>
            </div>
          </motion.div>

          <motion.div
            initial={{ opacity: 0, x: isRtl ? -34 : 34 }}
            whileInView={{ opacity: 1, x: 0 }}
            viewport={{ once: true }}
          >
            <div className="adbs-eyebrow">
              <ShieldCheck size={15} />
              WHY ADBS
            </div>

            <h2 className="adbs-title">
              {t('home.why.title.p1')}{' '}
              <span className="accent">{t('home.why.title.accent')}</span>{' '}
              {t('home.why.title.p2')}
            </h2>

            <div className="adbs-why-list">
              {whyItems.map((item, index) => (
                <motion.div
                  key={item.title}
                  initial={{ opacity: 0, y: 18 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ delay: index * 0.06 }}
                  className="adbs-why-item"
                >
                  <div className="adbs-why-icon">
                    <CheckCircle2 size={23} />
                  </div>
                  <div>
                    <h4>{item.title}</h4>
                    <p>{item.desc}</p>
                  </div>
                </motion.div>
              ))}
            </div>
          </motion.div>
        </div>
      </section>

      <section className="adbs-cta">
        <div className="adbs-cta-card">
          <div className="adbs-eyebrow mx-auto mb-6">
            START WITH CONFIDENCE
          </div>

          <h2>{t('services.cta_title')}</h2>
          <p>{t('hero.description')}</p>

          <Link to="/contact" className="adbs-primary-link">
            {t('services.cta_button')}
            <ArrowIcon size={18} />
          </Link>
        </div>
      </section>
    </main>
  );
